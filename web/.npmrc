# Refuse to install any package published less than 7 days ago.
# NPM packages keep getting compromised. I refuse to be compromised even if it's mildly annoying.
min-release-age=7
# Block scripts from running as part of installation. We should never need this probably.
ignore-scripts=true
# `npm install <package>` writes the EXACT version, no ^ range.
save-exact=true
# All contributors must be on a npm new enough for `min-release-age`.
engine-strict=true

fund=false
